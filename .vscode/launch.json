{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "aws-sam",
            "request": "direct-invoke",
            "name": "Debug Invoke Lambda",
            "invokeTarget": {
                "target": "template",
                "templatePath": "${workspaceFolder}/infra/template.yaml",
                "logicalId": "InvokeFunction"
            },
            "lambda": {
                "payload": {
                    "json": {
                        "orderId": "123",
                        "amount": 50
                    }
                }
            }
        }
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\src\\invoke\\index.ts",
            "preLaunchTask": "tsc: build - tsconfig.json",
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ]
        }
    ]
}